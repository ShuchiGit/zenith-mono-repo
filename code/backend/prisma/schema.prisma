generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  UNDER_CONSTRUCTION
  READY_TO_MOVE
  NEW_LAUNCH
}

enum PropertyType {
  FLAT
  SHOP
  PLOT
  STUDIO_APARTMENT
}

enum EnquiryStatus {
  NEW
  CONTACTED
  CLOSED
}

model Project {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(255)
  slug        String        @unique @db.VarChar(300)
  location    String        @db.VarChar(255)
  sector      String?       @db.VarChar(100)
  city        String        @db.VarChar(100)
  bhkTypes    String        @db.VarChar(100)
  priceMin    Decimal       @db.Decimal(15, 2)
  priceMax    Decimal       @db.Decimal(15, 2)
  status      ProjectStatus
  description String?       @db.LongText
  highlights  String?       @db.Text
  amenities   String?       @db.Text
  images      String?       @db.Text
  coverImage  String?       @db.VarChar(500)
  reraNumber  String?       @db.VarChar(100)
  builderName String?       @db.VarChar(255)
  totalUnits  Int?
  isActive    Boolean       @default(true)
  isFeatured  Boolean       @default(false)
  metaTitle   String?       @db.VarChar(255)
  metaDesc    String?       @db.VarChar(500)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  enquiries   Enquiry[]
  @@index([status])
  @@index([city])
  @@index([isActive])
}

model Property {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(255)
  slug        String        @unique @db.VarChar(300)
  location    String        @db.VarChar(255)
  sector      String?       @db.VarChar(100)
  city        String        @db.VarChar(100)
  bhkType     String        @db.VarChar(50)
  price       Decimal       @db.Decimal(15, 2)
  type        PropertyType
  status      ProjectStatus
  description String?       @db.LongText
  highlights  String?       @db.Text
  images      String?       @db.Text
  coverImage  String?       @db.VarChar(500)
  carpetArea  Decimal?      @db.Decimal(10, 2)
  superArea   Decimal?      @db.Decimal(10, 2)
  floor       Int?
  totalFloors Int?
  isActive    Boolean       @default(true)
  isFeatured  Boolean       @default(false)
  metaTitle   String?       @db.VarChar(255)
  metaDesc    String?       @db.VarChar(500)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  enquiries   Enquiry[]
  @@index([type])
  @@index([status])
  @@index([city])
}

model Enquiry {
  id         Int           @id @default(autoincrement())
  name       String        @db.VarChar(100)
  phone      String        @db.VarChar(20)
  email      String?       @db.VarChar(255)
  message    String?       @db.Text
  source     String        @db.VarChar(50)
  status     EnquiryStatus @default(NEW)
  notes      String?       @db.Text
  projectId  Int?
  propertyId Int?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  project    Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  property   Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  @@index([status])
  @@index([createdAt])
}

model Video {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  youtubeUrl  String    @db.VarChar(500)
  youtubeId   String    @db.VarChar(50)
  description String?   @db.Text
  views       String?   @db.VarChar(20)
  duration    String?   @db.VarChar(10)
  publishedAt DateTime?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  label     String?  @db.VarChar(255)
  updatedAt DateTime @updatedAt
}

model Admin {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  name         String?   @db.VarChar(100)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SeoPage {
  id        Int      @id @default(autoincrement())
  path      String   @unique @db.VarChar(500)
  metaTitle String?  @db.VarChar(255)
  metaDesc  String?  @db.VarChar(500)
  h1        String?  @db.VarChar(255)
  content   String?  @db.LongText
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
